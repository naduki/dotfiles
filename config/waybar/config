{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": ["sway/workspaces", "sway/window"],
    "modules-center": ["mpris", "clock"],
    "modules-right": ["pulseaudio", "network", "bluetooth", "tray", "custom/wlogout"],
    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}",
